{
  "compileOnSave": true,
  "compilerOptions": {
    "target": "esnext", // 指定ECMAScript目标版本 "ES3"（默认）， "ES5"， "ES6"/ "ES2015"， "ES2016"， "ES2017"或 "esnext"
    "lib": ["dom", "dom.iterable", "esnext"], // 编译过程中需要引入的库文件的列表
    "module": "esnext", // 指定生成哪个模块系统代码 "None"， "CommonJS"， "AMD"， "System"， "UMD"， "ES6"或 "ES2015"。
    "moduleResolution": "node", // 决定如何处理模块。或者是"Node"对于Node.js/io.js，或者是"Classic"（默认）
    "strict": false, // 启用所有严格类型检查选项。
    "jsx": "react-jsx", // 在 .tsx文件里支持JSX
    "allowJs": true, // 允许编译javascript文件。
    "sourceMap": true, // 生成相应的 .map文件。
    "inlineSources": true, // 将代码与sourcemaps生成到一个文件中
    "types": ["node"], // 要包含的类型声明文件名列表
    "allowSyntheticDefaultImports": true, // 允许从没有设置默认导出的模块中默认导入。这并不影响代码的输出，仅为了类型检查。
    "experimentalDecorators": true, // 启用实验性的ES装饰器。
    "declaration": true, // 生成相应的 .d.ts文件。
    "noEmit": true, // 根配置仅用于类型检查，避免输出覆盖源码
    "esModuleInterop": true, // 允许从没有设置默认导出的模块中默认导入
    "forceConsistentCasingInFileNames": true, // 禁止对同一个文件的不一致的引用。
    "importHelpers": true, // 从 tslib 导入辅助工具函数
    "noImplicitReturns": false, // 不是函数的所有返回路径都有返回值时报错。
    "newLine": "lf", // 当生成文件时指定行结束符： "crlf"（windows）或 "lf"（unix）。
    "noImplicitAny": false, // 在表达式和声明上有隐含的 any类型时报错。
    "resolveJsonModule": true,
    "skipLibCheck": true, // 忽略所有的声明文件（ *.d.ts）的类型检查。
    "typeRoots": ["./node_modules/@types"], // 要包含的类型声明文件路径列表
    "noUnusedLocals": false,
    "ignoreDeprecations": "5.0",
    "paths": {}
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": ["node_modules", "dist", "**/dist"]
}
