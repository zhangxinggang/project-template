{
  "name": "project-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "commit": "git-cz",
    "dev:electron": "pnpm --filter @momo/electron electron-dev",
    "dev:server": "pnpm --filter @momo/server dev",
    "format": "prettier --write \"./apps/**/*.{js,ts,tsx}\" \"./packages/**/*.{js,ts,tsx}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^17.7.2",
    "@commitlint/config-conventional": "^17.7.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/node": "^25.5.0",
    "@umijs/fabric": "^4.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "husky": "^8.0.3",
    "lint-staged": "^13.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-packagejson": "^2.5.19",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "stylelint-config-prettier>stylelint": ">=11 <16",
        "stylelint-scss>stylelint": "^15.11.0 || ^16.8.2 || ^17.0.0"
      }
    }
  }
}
