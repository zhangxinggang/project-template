{
  "appId": "com.jgraph.drawio.desktop",
  "copyright": "Copyright 2017-2026 draw.io Ltd",
  "asar": true,
  "files": [
    {
      "from": "dist/master",
      "to": "master"
    },
    "package.json"
  ],
  "directories": {
    "output": "out"
  },
  "npmRebuild": false,
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "artifactName": "${productName}-${version}-windows-installer.${ext}",
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "runAfterFinish": false,
    "createDesktopShortcut": false
  },
  "afterPack": "./scripts/build/afterPack.js"
}
